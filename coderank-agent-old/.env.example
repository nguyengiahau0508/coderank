# Server
PORT=4000

# LLM Provider (gemini | ollama | groq)
DEFAULT_MODEL_PROVIDER=gemini

# Gemini
GEMINI_API_KEY=your_gemini_api_key
DEFAULT_GEMINI_MODEL=gemini-2.5-flash

# Ollama (local)
OLLAMA_HOST=http://localhost:11434
DEFAULT_OLLAMA_MODEL=qwen2.5

# Groq
GROQ_API_KEY=your_groq_api_key
DEFAULT_GROQ_MODEL=llama-3.3-70b-versatile

# Agent Authentication (must match AGENT_SECRET_TOKEN in coderank-api .env)
AGENT_SECRET_TOKEN=your_agent_secret_token

# CodeRank API Connection
NESTJS_API_URL=http://localhost:3000/api

# Context Window Settings
CONTEXT_WINDOW_MAX_INPUT_TOKENS=12000
CONTEXT_WINDOW_OUTPUT_RESERVE_TOKENS=2000
CONTEXT_WINDOW_HISTORY_RETENTION_RATIO=0.8
CONTEXT_WINDOW_TOOL_RESULT_MAX_CHARS=6000
CONTEXT_WINDOW_TOOL_RESULTS_MAX_TOTAL_CHARS=12000
CONTEXT_WINDOW_SUMMARY_MAX_CHARS=1200

# Hook System (optional)
AGENT_HOOKS_LOGGING_ENABLED=false
AGENT_HOOKS_LOGGING_VERBOSE=false

# Session Persistence (optional)
SESSION_STORAGE_PATH=./.sessions
