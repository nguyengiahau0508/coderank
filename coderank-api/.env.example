# Application
APP_NAME=CodeRank API
APP_ENV=development
APP_HOST=localhost
APP_PORT=3000
APP_URL=http://localhost:3000
CLIENT_URL=http://localhost:4200

# MariaDB Database
DB_MARIADB_HOST=localhost
DB_MARIADB_PORT=3306
DB_MARIADB_USERNAME=root
DB_MARIADB_PASSWORD=your_password_here
DB_MARIADB_NAME=coderank

# JWT Authentication
AUTH_JWT_ACCESS_TOKEN_SECRET=your_access_token_secret
AUTH_JWT_ACCESS_TOKEN_EXPIRES_IN=15m
AUTH_JWT_REFRESH_TOKEN_SECRET=your_refresh_token_secret
AUTH_JWT_REFRESH_TOKEN_EXPIRES_IN=7d
AUTH_JWT_EMAIL_VERIFICATION_TOKEN_SECRET=your_email_verification_secret
AUTH_JWT_EMAIL_VERIFICATION_TOKEN_EXPIRES_IN=24h
AUTH_JWT_PASSWORD_RESET_TOKEN_SECRET=your_password_reset_secret
AUTH_JWT_PASSWORD_RESET_TOKEN_EXPIRES_IN=1h

# GitHub OAuth
INTEGRATIONS_GITHUB_CLIENT_ID=your_github_client_id
INTEGRATIONS_GITHUB_CLIENT_SECRET=your_github_client_secret

# Google OAuth & Drive
INTEGRATIONS_GOOGLE_CLIENT_ID=your_google_client_id
INTEGRATIONS_GOOGLE_CLIENT_SECRET=your_google_client_secret
INTEGRATIONS_GOOGLE_OAUTH2_CLIENT_EMAIL=your_google_oauth2_email
INTEGRATIONS_GOOGLE_OAUTH2_PRIVATE_KEY=your_google_oauth2_private_key
INTEGRATIONS_GOOGLE_OAUTH2_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
INTEGRATIONS_GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id
